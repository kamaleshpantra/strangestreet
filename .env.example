# Strange Street — Environment Configuration
# Rename this file to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/strangestreet

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# AES-256 encryption key for messages. Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Application ───────────────────────────────────────────────────────────────
# Set to false in production to hide tracebacks and disable /docs
DEBUG=true

# Max file upload size in megabytes
MAX_UPLOAD_SIZE_MB=10

# ── Cloudinary (optional — enables CDN media storage) ────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
